---
const year = new Date().getFullYear();
---

<footer class="border-t border-border py-8 mt-auto">
  <div class="max-w-5xl mx-auto px-6 flex flex-col sm:flex-row items-center justify-between gap-4">
    <p class="text-xs text-text-sub">
      &copy; {year} insong
    </p>
    <div class="flex items-center gap-6">
      <a
        href="https://github.com/kim-insong"
        class="text-xs text-text-sub hover:text-text transition-colors"
        target="_blank"
        rel="noopener noreferrer"
      >
        GitHub
      </a>
    </div>
  </div>
</footer>
