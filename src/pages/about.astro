---

<BaseLayout title="소개" description="김인송 소개 — 게임 개발자">
  <!-- Header -->
  <section class="py-24 md:py-36 px-6">
    <div class="max-w-5xl w-full mx-auto">
      <div class="max-w-xl animate-reveal">
        <span class="section-label">About</span>
        <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-4">
          김인송
        </h1>
        <p class="text-text-sub leading-relaxed">
          게임 개발자입니다. 클라이언트·데디서버·웹서버·소켓서버부터 윈도우 툴·웹서비스·모바일 앱까지, 게임을 둘러싼 다양한 영역을 두루 경험해왔습니다.
        </p>
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="py-20 px-6 border-t border-border bg-bg-alt">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8 animate-reveal">
        <span class="section-label">Education</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">학력</h2>
      </div>
      <div class="divide-y divide-border animate-reveal delay-1">
        {educations.map(edu => (
          <div class="py-5 first:pt-0 last:pb-0">
            <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 mb-3">
              <span class="text-xs text-text-sub tabular-nums shrink-0 w-32">{edu.period}</span>
              <div class="flex items-baseline gap-2">
                <span class="text-sm font-semibold text-text">{edu.org}</span>
                {edu.note && <span class="text-sm text-text-sub">{edu.note}</span>}
              </div>
            </div>
            {edu.items.length > 0 && (
              <div class="sm:pl-36 flex flex-col gap-2">
                {edu.items.map(item => (
                  <div class="flex flex-col sm:flex-row gap-1 sm:gap-4">
                    <span class="text-xs text-text-sub tabular-nums shrink-0 w-36">{item.date}</span>
                    <div class="flex flex-col gap-1">
                      <div class="flex items-baseline gap-2 flex-wrap">
                        <span class="text-sm text-text-sub">{item.desc}</span>
                        {item.award && (
                          <span class="text-xs font-medium text-text bg-bg-alt border border-border rounded px-2 py-0.5 shrink-0">{item.award}</span>
                        )}
                      </div>
                      {item.stack && (
                        <div class="flex flex-wrap gap-1.5">
                          {item.stack.map(s => (
                            <span class="text-xs font-medium text-text-sub bg-bg border border-border rounded px-2 py-0.5">{s}</span>
                          ))}
                        </div>
                      )}
                    </div>
                  </div>
                ))}
              </div>
            )}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Career -->
  <section class="py-20 px-6 border-t border-border bg-bg-alt">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8 animate-reveal">
        <span class="section-label">Experience</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">경력</h2>
      </div>
      <div class="divide-y divide-border animate-reveal delay-1">
        {careers.map(item => (
          <div class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-4 py-5 first:pt-0 last:pb-0">
            <span class="text-xs text-text-sub tabular-nums shrink-0 w-32 pt-0.5">{item.period}</span>
            <div class="flex-1">
              <div class="text-sm font-semibold text-text mb-1.5">{item.org}</div>
              <ul class="flex flex-col gap-2">
                {item.projects.map(p => (
                  <li class="flex flex-col gap-1">
                    <div class="flex items-baseline gap-2 flex-wrap">
                      <span class="text-sm text-text-sub">{p.name}</span>
                      {p.tags && p.tags.map((t: string) => (
                        <span class={tagStyles[t]}>{t}</span>
                      ))}
                      {p.period && <span class="text-xs text-text-sub tabular-nums">{p.period}</span>}
                      {p.roles && p.roles.map(r => (
                        <span class="text-xs font-medium text-text border border-border rounded px-1.5 py-0.5">{r}</span>
                      ))}
                    </div>
                    {p.highlights && (
                      <ul class="flex flex-col gap-0.5">
                        {p.highlights.map(h => (
                          <li class="text-xs text-text-sub">— {h}</li>
                        ))}
                      </ul>
                    )}
                    {p.stack && (
                      <div class="flex flex-wrap gap-1.5">
                        {p.stack.map(s => (
                          <span class="text-xs font-medium text-text-sub bg-bg border border-border rounded px-2 py-0.5">{s}</span>
                        ))}
                      </div>
                    )}
                  </li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="py-20 px-6 border-t border-border bg-bg">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8 animate-reveal">
        <span class="section-label">Skills</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">스킬 & 스택</h2>
      </div>
      <div class="flex flex-col gap-6 animate-reveal delay-1">
        {skills.map(group => (
          <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
            <span class="text-xs text-text-sub shrink-0 w-32 pt-0.5">{group.category}</span>
            <div class="flex flex-wrap gap-2">
              {group.items.map(item => (
                <span class="text-xs font-medium text-text bg-bg-alt border border-border rounded-lg px-3 py-1.5">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
