---
import BaseLayout from '../layouts/BaseLayout.astro';

const education = {
  period: '2005 — 2010',
  org: '서울대학교 컴퓨터공학부',
  items: [
    { date: '2007.01–03', desc: '포스데이타(POSDATA) FLYVO팀 인턴십' },
    { date: '2007.09–12', desc: '현대오토넷 화상통화프로그램 프로젝트' },
    { date: '2007.09', desc: '제10회 SNU CSE 컴퓨터전시회 출품 — 절대음감 (ansp팀, 팀장)' },
    { date: '2007.11', desc: '2007 창의적 종합설계 경진대회(Capstone Design) 출품 — 절대음감 (ansp팀)' },
    { date: '2008.01–06', desc: 'Uppsala University 교환학생 (스웨덴)' },
    { date: '2008.07–08', desc: '다음(Daum) 컨텐츠개발팀 인턴십' },
    { date: '2008.09', desc: '제11회 SNU CSE 컴퓨터전시회 출품 — 미라클 (new Miracle 팀, 팀장)' },
    { date: '2008.11', desc: '2008 창의적 종합설계 경진대회(Capstone Design) 출품 — 미라클 (new Miracle 팀, 팀장)' },
    { date: '2008.07–2009.03', desc: '서울대학교 컴퓨터공학부 학부커뮤니티 개발' },
  ],
};

const careers = [
  {
    period: '2009 — 2013',
    org: '(주)컴투스',
    projects: [
      '액션퍼즐패밀리3 (제한적 참여)',
      '초코초코타이쿤2',
      '초콜릿타이쿤',
      '프로토타입 1종 (드랍)',
    ],
  },
  {
    period: '2013 — 2014',
    org: '(주)게임하이',
    projects: [
      '프로토타입 1종 (드랍)',
      '몬몬몬',
    ],
  },
  {
    period: '2014 — 2017',
    org: '(주)넥슨GT',
    projects: [
      '서든어택2',
    ],
  },
  {
    period: '2017 — 2019',
    org: '(주)넥슨레드',
    projects: [
      '포인트 블랭크: 스트라이크',
      '프로토타입 1종 (드랍)',
    ],
  },
  {
    period: '2020 — 현재',
    org: '(주)넥슨코리아',
    projects: [
      '프라시아전기',
      '프로젝트EL (드랍)',
    ],
  },
];

const skills = [
  { category: '언어', items: ['C++', 'C#', 'Python', 'Groovy', 'Swift'] },
  { category: '게임엔진 / 프레임워크', items: ['Cocos2d-x', 'Unity3D', 'UnrealEngine', 'SwiftUI', 'WPF'] },
  { category: '협업 / 버전관리', items: ['Git', 'SVN', 'Perforce', 'Jira', 'Confluence', 'Jenkins'] },
  { category: '데이터베이스', items: ['MSSQL', 'MySQL', 'Redis'] },
];

const awards = [
  { date: '2007.09.24', desc: '제10회 SNU CSE 컴퓨터전시회 인기상' },
  { date: '2007.11.22', desc: '2007 창의적 종합설계 경진대회 산업자원부장관상' },
  { date: '2008.09.24', desc: '제11회 SNU CSE 컴퓨터전시회 우수상' },
  { date: '2008.11.06', desc: '2008 창의적 종합설계 경진대회 교육과학기술부장관상' },
];
---

<BaseLayout title="소개" description="김인송 소개 — 게임 개발자">
  <!-- Header -->
  <section class="py-24 md:py-36 px-6">
    <div class="max-w-5xl w-full mx-auto">
      <div class="max-w-xl animate-reveal">
        <span class="section-label">About</span>
        <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-4">
          김인송
        </h1>
        <p class="text-text-sub leading-relaxed">
          게임 개발자입니다. 서울대학교 컴퓨터공학부를 졸업하고,
          컴투스·게임하이·넥슨 등에서 모바일·PC 게임 개발에 참여해왔습니다.
          좋은 게임은 매 순간 플레이어가 다음 행동을 자연스럽게 알 수 있어야 한다고 생각합니다.
        </p>
      </div>
    </div>
  </section>

  <!-- Education -->
  <section class="py-20 px-6 border-t border-border bg-bg-alt">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8 animate-reveal">
        <span class="section-label">Education</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">학력</h2>
      </div>
      <div class="animate-reveal delay-1">
        <div class="flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-4 mb-4">
          <span class="text-xs text-text-sub tabular-nums shrink-0 w-32">{education.period}</span>
          <div class="text-sm font-semibold text-text">{education.org}</div>
        </div>
        <div class="sm:pl-36 flex flex-col gap-2">
          {education.items.map(item => (
            <div class="flex flex-col sm:flex-row gap-1 sm:gap-4">
              <span class="text-xs text-text-sub tabular-nums shrink-0 w-36">{item.date}</span>
              <span class="text-sm text-text-sub">{item.desc}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- Career -->
  <section class="py-20 px-6 border-t border-border bg-bg">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8 animate-reveal">
        <span class="section-label">Experience</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">경력</h2>
      </div>
      <div class="divide-y divide-border animate-reveal delay-1">
        {careers.map(item => (
          <div class="flex flex-col sm:flex-row sm:items-start gap-1 sm:gap-4 py-5 first:pt-0 last:pb-0">
            <span class="text-xs text-text-sub tabular-nums shrink-0 w-32 pt-0.5">{item.period}</span>
            <div class="flex-1">
              <div class="text-sm font-semibold text-text mb-1.5">{item.org}</div>
              <ul class="flex flex-col gap-1">
                {item.projects.map(p => (
                  <li class="text-sm text-text-sub">{p}</li>
                ))}
              </ul>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Skills -->
  <section class="py-20 px-6 border-t border-border bg-bg">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8 animate-reveal">
        <span class="section-label">Skills</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">스킬 & 스택</h2>
      </div>
      <div class="flex flex-col gap-6 animate-reveal delay-1">
        {skills.map(group => (
          <div class="flex flex-col sm:flex-row gap-2 sm:gap-4">
            <span class="text-xs text-text-sub shrink-0 w-32 pt-0.5">{group.category}</span>
            <div class="flex flex-wrap gap-2">
              {group.items.map(item => (
                <span class="text-xs font-medium text-text bg-bg-alt border border-border rounded-lg px-3 py-1.5">{item}</span>
              ))}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- Awards -->
  <section class="py-20 px-6 border-t border-border bg-bg-alt">
    <div class="max-w-5xl mx-auto">
      <div class="mb-8 animate-reveal">
        <span class="section-label">Awards</span>
        <h2 class="text-2xl font-semibold text-text tracking-tight">수상경력</h2>
      </div>
      <div class="divide-y divide-border animate-reveal delay-1">
        {awards.map(award => (
          <div class="flex flex-col sm:flex-row gap-1 sm:gap-4 py-4 first:pt-0 last:pb-0">
            <span class="text-xs text-text-sub tabular-nums shrink-0 w-32">{award.date}</span>
            <span class="text-sm text-text-sub">{award.desc}</span>
          </div>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
