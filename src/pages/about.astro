---
import BaseLayout from '../layouts/BaseLayout.astro';

const educations = [
  {
    period: '2005 — 2010',
    org: '서울대학교 컴퓨터공학부',
    items: [
      { date: '2007.09–12', desc: '현대오토넷 화상통화프로그램 프로젝트', stack: ['C#', 'WinCE'] },
      { date: '2007.09', desc: '제10회 SNU CSE 컴퓨터전시회 출품 — 절대음감 (ansp팀, 팀장)', stack: ['C++'] },
      { date: '2007.11', desc: '2007 창의적 종합설계 경진대회(Capstone Design) 출품 — 절대음감 (ansp팀)', stack: ['C#'] },
      { date: '2008.09', desc: '제11회 SNU CSE 컴퓨터전시회 출품 — 미라클 (new Miracle 팀, 팀장)', stack: ['C#'] },
      { date: '2008.11', desc: '2008 창의적 종합설계 경진대회(Capstone Design) 출품 — 미라클 (new Miracle 팀, 팀장)', stack: ['C#'] },
      { date: '2008.07–2009.03', desc: '학부커뮤니티 개발', stack: ['C#', 'ASP.NET', 'MS-SQL'] },
    ],
  },
  {
    period: '2008.01–06',
    org: 'Uppsala University',
    note: 'Sweden, 교환학생',
    items: [],
  },
];

const careers = [
  {
    period: '2007.01–03',
    org: '포스데이타(POSDATA)',
    projects: [
      { name: 'FLYVO팀 인턴십', stack: ['C'] },
    ],
  },
  {
    period: '2008.07–08',
    org: '다음(Daum)',
    projects: [
      { name: '컨텐츠개발팀 인턴십', stack: ['Java', 'Spring'] },
    ],
  },
  {
    period: '2009 — 2013',
    org: '(주)컴투스',
    projects: [
      { name: '액션퍼즐패밀리3 (제한적 참여)', roles: ['클라이언트'], stack: ['위피C'] },
      { name: '초코초코타이쿤2', roles: ['클라이언트'], stack: ['위피C'] },
      { name: '초콜릿타이쿤', roles: ['클라이언트'], stack: ['위피C'] },
      { name: '프로토타입 1종 (드랍)', roles: ['클라이언트'], stack: ['C++', 'Box2d'] },
      { name: '프로토타입 1종 (드랍)', roles: ['클라이언트'], stack: ['C#', 'Unity3D'] },
      { name: '프로토타입 1종 (드랍)', roles: ['클라이언트'], stack: ['C++'] },
    ],
  },
  {
    period: '2013 — 2014',
    org: '(주)게임하이',
    projects: [
      { name: '프로토타입 1종 (드랍)', roles: ['클라이언트'], stack: ['C++', 'Cocos2d-x'] },
      { name: '몬몬몬', roles: ['클라이언트', '웹서버'], stack: ['C++', 'C#', 'Cocos2d-x', 'ASP.NET', 'WinForms', 'MSSQL', 'Redis', 'Lua'] },
    ],
  },
  {
    period: '2014 — 2017',
    org: '(주)넥슨GT',
    projects: [
      { name: '서든어택2', roles: ['클라이언트'], stack: ['C++', 'UnrealEngine'] },
    ],
  },
  {
    period: '2017 — 2019',
    org: '(주)넥슨레드',
    projects: [
      { name: '포인트 블랭크: 스트라이크', roles: ['웹서버'], stack: ['PHP', 'MySQL', 'Redis'] },
      { name: '프로토타입 1종 (드랍)', roles: ['클라이언트'], stack: ['C++', 'UnrealEngine'] },
    ],
  },
  {
    period: '2020 — 현재',
    org: '(주)넥슨코리아',
    projects: [
