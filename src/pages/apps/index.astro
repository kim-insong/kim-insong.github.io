---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const apps = (await getCollection('apps'))
  .filter(app => !app.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="앱" description="김인송이 개발중인 iOS 앱">
  <!-- Header -->
  <section class="py-24 md:py-36 px-6">
    <div class="max-w-5xl w-full mx-auto">
      <div class="max-w-xl animate-reveal">
        <span class="section-label">Apps</span>
        <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-4">앱</h1>
        <p class="text-text-sub leading-relaxed">
          직접 기획하고 개발 중인 iOS 앱들입니다.
        </p>
      </div>
    </div>
  </section>

  <!-- App list -->
  <section class="py-20 px-6 border-t border-border bg-bg-alt">
    <div class="max-w-5xl mx-auto">
      <div class="grid grid-cols-1 gap-4 animate-reveal">
        {apps.map(app => (
          <a
            href={`/apps/${app.slug}`}
            class="group block bg-card border border-border rounded-2xl p-6 hover:shadow-md transition-shadow"
          >
            <div class="flex items-start justify-between gap-4 mb-3">
              <h2 class="text-sm font-semibold text-text group-hover:text-primary transition-colors">
                {app.data.title}
              </h2>
              <div class="flex gap-2 shrink-0">
                <span class="text-xs px-2 py-0.5 rounded-md bg-muted text-text-sub border border-border">
                  {app.data.platform}
                </span>
                <span class="text-xs px-2 py-0.5 rounded-md bg-muted text-text-sub border border-border">
                  {app.data.status}
                </span>
              </div>
            </div>
            <p class="text-sm text-text-sub leading-relaxed mb-3">
              {app.data.tagline}
            </p>
            <p class="text-xs text-text-sub leading-relaxed">
              {app.data.description}
            </p>
          </a>
        ))}
      </div>
    </div>
  </section>
</BaseLayout>
