---
import BaseLayout from '../../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const posts = (await getCollection('blog'))
  .filter(post => !post.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());
---

<BaseLayout title="블로그" description="김인송의 글">
  <!-- Header -->
  <section class="py-24 md:py-36 px-6">
    <div class="max-w-5xl w-full mx-auto">
      <div class="max-w-xl animate-reveal">
        <span class="section-label">Writing</span>
        <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-4">
          블로그
        </h1>
        <p class="text-text-sub leading-relaxed">
          iOS 개발, 인디 비즈니스, 제품 만들기에 관한 기록.
        </p>
      </div>
    </div>
  </section>

  <!-- Posts -->
  <section class="py-10 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto">
      {posts.length === 0 ? (
        <p class="text-sm text-text-sub">아직 글이 없습니다. 곧 업데이트됩니다.</p>
      ) : (
        <div class="divide-y divide-border">
          {posts.map((post, i) => (
            <a
              href={`/blog/${post.slug}`}
              class={`group flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-6 py-5 first:pt-0 hover:bg-bg-alt -mx-4 px-4 rounded-xl transition-colors animate-reveal delay-${Math.min(i + 1, 4)}`}
            >
              <span class="text-xs text-text-sub tabular-nums shrink-0 w-28">
                {post.data.publishDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
              <div class="flex-1">
                <div class="text-sm font-semibold text-text group-hover:text-primary transition-colors">
                  {post.data.title}
                </div>
                {post.data.description && (
                  <div class="text-sm text-text-sub mt-0.5">{post.data.description}</div>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
