---
import BaseLayout from '../../layouts/BaseLayout.astro';
import WikiSearch from '../../components/WikiSearch';
import { getCollection } from 'astro:content';

const allEntries = (await getCollection('wiki'))
  .filter(e => !e.data.draft)
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf());

const activeTag = Astro.url.searchParams.get('tag');
const entries = activeTag
  ? allEntries.filter(e => e.data.tags?.includes(activeTag))
  : allEntries;

const allTags = [...new Set(allEntries.flatMap(e => e.data.tags ?? []))].sort();
---

<BaseLayout title="위키" description="개발 인사이트와 지식 노트 모음.">
  <!-- Header -->
  <section class="py-24 md:py-36 px-6">
    <div class="max-w-5xl w-full mx-auto">
      <div class="max-w-xl animate-reveal">
        <span class="section-label">Knowledge Base</span>
        <h1 class="text-3xl md:text-4xl font-semibold text-text tracking-tight mb-4">
          위키
        </h1>
        <p class="text-text-sub leading-relaxed">
          개발 인사이트와 지식 노트 모음.
        </p>
      </div>
    </div>
  </section>

  <!-- Search + Filter + List -->
  <section class="py-10 px-6 border-t border-border">
    <div class="max-w-5xl mx-auto">
      <WikiSearch client:load />

      <!-- Tag filter -->
      {allTags.length > 0 && (
        <div class="flex flex-wrap gap-2 mb-8">
          <a
            href="/wiki"
            class={`text-xs px-3 py-1 rounded-md border transition-colors ${
              !activeTag
                ? 'bg-primary text-white border-primary'
                : 'border-border text-text-sub hover:text-text'
            }`}
          >
            전체
          </a>
          {allTags.map(tag => (
            <a
              href={`/wiki?tag=${tag}`}
              class={`text-xs px-3 py-1 rounded-md border transition-colors ${
                activeTag === tag
                  ? 'bg-primary text-white border-primary'
                  : 'border-border text-text-sub hover:text-text'
              }`}
            >
              {tag}
            </a>
          ))}
        </div>
      )}

      <!-- Entry list -->
      {entries.length === 0 ? (
        <p class="text-sm text-text-sub">아직 노트가 없습니다.</p>
      ) : (
        <div class="divide-y divide-border">
          {entries.map((entry, i) => (
            <a
              href={`/wiki/${entry.slug}`}
              class={`group flex flex-col sm:flex-row sm:items-baseline gap-1 sm:gap-6 py-5 first:pt-0 hover:bg-bg-alt -mx-4 px-4 rounded-xl transition-colors animate-reveal delay-${Math.min(i + 1, 4)}`}
            >
              <span class="text-xs text-text-sub tabular-nums shrink-0 w-28">
                {entry.data.publishDate.toLocaleDateString('ko-KR', { year: 'numeric', month: 'short', day: 'numeric' })}
              </span>
              <div class="flex-1">
                <div class="text-sm font-semibold text-text group-hover:text-primary transition-colors">
                  {entry.data.title}
                </div>
                {entry.data.description && (
                  <div class="text-sm text-text-sub mt-0.5">{entry.data.description}</div>
                )}
                {entry.data.tags && entry.data.tags.length > 0 && (
                  <div class="flex flex-wrap gap-1 mt-1.5">
                    {entry.data.tags.map((tag: string) => (
                      <span class="text-xs px-2 py-0.5 rounded bg-muted text-muted-foreground">
                        {tag}
                      </span>
                    ))}
                  </div>
                )}
              </div>
            </a>
          ))}
        </div>
      )}
    </div>
  </section>
</BaseLayout>
